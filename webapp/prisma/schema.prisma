  hydraThreads                          Int      @default(16) @map("hydra_threads")
  hydraWaitBetweenConnections           Int      @default(0) @map("hydra_wait_between_connections")
  hydraConnectionTimeout                Int      @default(32) @map("hydra_connection_timeout")
  hydraStopOnFirstFound                 Boolean  @default(true) @map("hydra_stop_on_first_found")
  hydraExtraChecks                      String   @default("nsr") @map("hydra_extra_checks")
  hydraVerbose                          Boolean  @default(true) @map("hydra_verbose")
  hydraMaxWordlistAttempts              Int      @default(3) @map("hydra_max_wordlist_attempts")

  // Shodan OSINT Settings (agent tool toggle — kept separate from pipeline features)
