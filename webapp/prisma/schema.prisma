  // ========== PHISHING / SOCIAL ENGINEERING SETTINGS ==========
  phishingSmtpConfig                    String   @default("") @map("phishing_smtp_config")

  // ========== DENIAL OF SERVICE SETTINGS ==========
  dosMaxDuration                        Int      @default(60) @map("dos_max_duration")
